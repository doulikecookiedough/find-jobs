{
  "manifest_version": 3,
  "name": "find-jobs",
  "version": "0.1.0",
  "description": "Evaluate job postings against the local find-jobs FastAPI service.",
  "permissions": ["activeTab", "scripting", "sidePanel"],
  "host_permissions": ["http://127.0.0.1:8000/*", "https://www.linkedin.com/*", "https://wellfound.com/*", "https://ca.indeed.com/*"],
  "action": {
    "default_title": "Evaluate job fit"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
